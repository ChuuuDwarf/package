import re
import csv
import os

# ===== 依你實際的 log 格式修改這三個 pattern =====
START_RE = re.compile(r"...starttime...")
END_RE   = re.compile(r"...endtime...")
ERROR_RE = re.compile(r"\bERROR\b", re.IGNORECASE)


def parse_log(path):
    """
    檢查單一 log。
    乾淨（有 start、有 end、start 之後沒 error）回傳 (start, end)，
    有問題回傳 None。
    """
    start_time = None
    end_time = None

    with open(path, "r", encoding="utf-8", errors="replace") as f:
        for line in f:                          # 逐行讀，6000 行也不吃記憶體
            if start_time is None:
                if START_RE.search(line):
                    start_time = line.strip()
                continue                        # start 之前都不管（含 error）
            if ERROR_RE.search(line):
                return None                     # 讀到 error 直接停、作廢
            if END_RE.search(line):
                end_time = line.strip()         # 持續更新，最後留下最後一個

    if start_time is None or end_time is None:  # 缺 start 或缺 end → 作廢
        return None
    return (start_time, end_time)


def process_logs(log_paths, output_csv):
    """把乾淨的 log 寫進 CSV：檔名、開始時間、結束時間。"""
    with open(output_csv, "w", newline="", encoding="utf-8-sig") as f:
        writer = csv.writer(f)
        writer.writerow(["filename", "start_time", "end_time"])  # 表頭

        for path in log_paths:
            result = parse_log(path)
            if result is None:
                continue                        # 有問題 → 跳過
            start_time, end_time = result
            writer.writerow([os.path.basename(path), start_time, end_time])


if __name__ == "__main__":
    log_dir = "logs"                            # 依你的實際路徑改
    logs = [
        os.path.join(log_dir, f)
        for f in os.listdir(log_dir)
        if f.endswith(".log")
    ]
    process_logs(logs, "result.csv")
